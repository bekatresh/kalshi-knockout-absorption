# Copy this file to .env (gitignored, never commit it) and fill in real
# values only if you need the OPTIONAL authenticated Kalshi endpoints
# (e.g. order-book depth). All market-data pulls used by this project
# (src/pull_data.py, simulator/live_inputs.py) are public and need none of
# this.
#
# Load with `python-dotenv` (pip install python-dotenv) or export manually:
#   export $(cat .env | xargs)

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
